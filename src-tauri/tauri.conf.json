{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Baz Studios",
  "version": "0.1.0",
  "identifier": "com.bazstudios.launcher",
  "build": {
    "frontendDist": "../src"
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://raw.githubusercontent.com/Baz-Studios-LLC/baz-studios-launcher/main/updater.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyMDJDQjM3RjQ4NkE5MzAKUldRd3FZYjBOOHNDSWxPN2pSU2V1cWtvU1c4T0pSekZ1WDZrSWwwT2k1eHFBNXR2aHFJSUdFL1EK"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Baz Studios",
        "width": 1040,
        "height": 640,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "maximizable": true,
        "decorations": true,
        "center": true,
        "backgroundColor": "#0a0b12"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
